{
  "name": "husu-habits",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "cap:sync": "npm run build && npx cap sync && node scripts/fix-spm-paths.mjs",
    "cap:sync:ios": "npm run build && npx cap sync ios && node scripts/fix-spm-paths.mjs",
    "cap:sync:android": "npm run build && npx cap sync android",
    "fix:spm": "node scripts/fix-spm-paths.mjs",
    "gen:icons": "node scripts/generate-android-icons.mjs",
    "test:logic": "tsx scripts/audit-logic.test.mts",
    "prep:ios": "node scripts/prep-ios-for-eas.mjs",
    "eas:ios": "npm run prep:ios && npx eas-cli@^19 build -p ios --profile production --auto-submit",
    "eas:android": "npx eas-cli@^19 build -p android --profile production --auto-submit --non-interactive",
    "eas:preview:ios": "npm run prep:ios && npx eas-cli@^19 build -p ios --profile preview",
    "eas:preview:android": "npx eas-cli@^19 build -p android --profile preview",
    "eas-build-pre-install": "node scripts/eas-pre-install.mjs",
    "eas-build-post-install": "node scripts/eas-post-install.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.3",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.3.3",
    "@capacitor/core": "^8.3.3",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/local-notifications": "^8.1.0",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  },
  "optionalDependencies": {
    "sharp": "^0.34.5"
  }
}
