<?xml version="1.0" encoding="utf-8"?>
<!--
  Husu Habits adaptive icon BACKGROUND.
  Vector drawable con gradiente clay (#C97B5A) -> ember (#E5A04C),
  igualando el bg del SVG legacy para look consistente entre
  legacy launchers (Android < 8) y adaptive launchers (Android 8+).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="0"
                android:startY="0"
                android:endX="108"
                android:endY="108"
                android:type="linear">
                <item android:offset="0.0" android:color="#FFC97B5A"/>
                <item android:offset="1.0" android:color="#FFE5A04C"/>
            </gradient>
        </aapt:attr>
    </path>
</vector>
